{
  "name": "pane",
  "version": "1.0.0",
  "description": "A powerful custom file manager for macOS",
  "main": "src/main/index.js",
  "scripts": {
    "start": "webpack --config webpack-renderer.js --mode development && electron .",
    "dev": "concurrently -k \"webpack --config webpack-renderer.js --mode development --watch\" \"sleep 4 && electron . \"",
    "renderer": "webpack --config webpack-renderer.js --mode development --watch",
    "electron": "electron .",
    "clean": "rm -rf dist/mac-* dist/*.dmg dist/*.zip dist/*.blockmap dist/latest-*.yml dist/builder-*.yml",
    "build": "npm run clean && npm run build:renderer && npm run build:electron",
    "build:renderer": "webpack --config webpack-renderer.js --mode production",
    "build:electron": "electron-builder --mac",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.5.4",
    "style-loader": "^3.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "mime-types": "^2.1.35",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.8",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^4.4.7",
    "path-browserify": "^1.0.1"
  },
  "build": {
    "appId": "com.pane.app",
    "productName": "Pane",
    "compression": "normal",
    "files": [
      "dist/index.html",
      "dist/renderer.js",
      "dist/*.renderer.js",
      "dist/assets/**/*",
      "src/main/**/*",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "node_modules/better-sqlite3",
        "to": "better-sqlite3"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "icon.icns",
      "darkModeSupport": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Pane",
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    }
  }
}